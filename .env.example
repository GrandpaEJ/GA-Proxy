# GA-Proxy Configuration

# Security
PROXY_SECRET=your_secret_handshake_key_here

# API Keys (Optional - only set what you want to provide)
# Get keys at:
# Groq: https://console.groq.com/
# OpenRouter: https://openrouter.ai/
# Cerebras: https://cloud.cerebras.ai/
GROQ_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=

# Rate Limiting (Optional)
RATE_LIMIT_MAX=20

# Server
PORT=3000
